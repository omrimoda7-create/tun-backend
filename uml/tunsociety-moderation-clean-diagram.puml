@startuml
title TunSociety - Moderation Pipeline Diagram
left to right direction
skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam nodesep 75
skinparam ranksep 75

skinparam component {
  BackgroundColor white
  BorderColor #355C7D
  FontColor #102A43
}
skinparam package {
  BackgroundColor #EEF4F8
  BorderColor #486581
  FontColor #243B53
}
skinparam database {
  BackgroundColor #F8FAFC
  BorderColor #355C7D
  FontColor #102A43
}
skinparam cloud {
  BackgroundColor #F8FAFC
  BorderColor #355C7D
  FontColor #102A43
}

actor User
actor "Moderator / Admin" as Reviewer

package "Moderated Inputs" {
  component "Registration full name" as FullName
  component "Profile display name" as DisplayName
  component "Post / post update" as Post
  component "Post comment" as Comment
  component "Friend request note" as FriendRequestNote
  component "Direct message" as DirectMessage
  component "Legacy message" as Message
}

package "Services" {
  component "ModerationService" as ModerationService
  component "AiScoringClient" as AiScoringClient
  component "SanctionService" as SanctionService
  component "AuditService" as AuditService
  database "ApplicationDbContext" as ApplicationDbContext
}

package "Persistence Artifacts" {
  component "ModerationResult" as ModerationResult
  component "Warning" as Warning
  component "Freeze" as Freeze
  component "Appeal" as Appeal
  component "AuditLog" as AuditLog
}

cloud "Ollama Local API\nhttp://localhost:11434\nmodel: deepseek-r1" as Ollama
component "Local heuristic\nfallback" as Fallback

User --> FullName
User --> DisplayName
User --> Post
User --> Comment
User --> FriendRequestNote
User --> DirectMessage
User --> Message

FullName --> ModerationService
DisplayName --> ModerationService
Post --> ModerationService
Comment --> ModerationService
FriendRequestNote --> ModerationService
DirectMessage --> ModerationService
Message --> ModerationService

ModerationService --> AiScoringClient : get score + flags
AiScoringClient --> Ollama : prompt
AiScoringClient --> Fallback : if local AI fails

ModerationService --> ModerationResult : action = Allow / Flag / Block
ModerationService --> SanctionService : only if action = Block
SanctionService --> Warning : create blocked-violation warning
SanctionService --> Freeze : create active freeze\non 3rd blocked violation

ModerationService --> ApplicationDbContext : save review record
SanctionService --> ApplicationDbContext : save warning / freeze
AuditService --> AuditLog : persist trace

Reviewer --> ModerationResult : review queue
Reviewer --> Warning : review warnings
Reviewer --> Freeze : review freezes
Reviewer --> Appeal : review appeals
Reviewer --> AuditLog : review actions

note bottom
Current backend behavior:
- Block => warning
- Freeze only after 3 blocked violations
- Appeal review exists for moderators/admins
- User-facing appeal submission is not currently exposed as a public endpoint
end note
@enduml
